<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Admin Dashboard | RIT Academia</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gray-100 min-h-screen">

<!-- Admin Navbar -->
<%- include("partials/navbar-admin") %>


<div class="max-w-7xl mx-auto px-6 py-10">

<!-- Page Title -->
<div class="flex justify-between items-center mb-8">
<h1 class="text-3xl font-bold text-gray-800">
Admin Dashboard
</h1>

<a href="/subjects/add"
class="bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700 transition">
+ Add Subject
</a>

</div>


<!-- Flash Messages -->

<% if (error.length > 0) { %>
<div class="mb-6 bg-red-100 text-red-700 px-4 py-3 rounded">
<%= error %>
</div>
<% } %>

<% if (success.length > 0) { %>
<div class="mb-6 bg-green-100 text-green-700 px-4 py-3 rounded">
<%= success %>
</div>
<% } %>



<!-- SUBJECT MANAGEMENT -->

<div class="bg-white shadow-lg rounded-xl p-6 mb-10">

<h2 class="text-xl font-semibold text-gray-700 mb-5">
Manage Subjects
</h2>

<% if (subjects.length === 0) { %>

<p class="text-gray-500">
No subjects added yet.
</p>

<% } else { %>

<div class="overflow-x-auto">

<table class="w-full text-left border-collapse">

<thead>

<tr class="border-b bg-gray-50">

<th class="py-3 px-4 font-semibold text-gray-700">Subject</th>
<th class="py-3 px-4 font-semibold text-gray-700">Branch</th>
<th class="py-3 px-4 font-semibold text-gray-700">Semester</th>
<th class="py-3 px-4 font-semibold text-gray-700 text-center">Actions</th>

</tr>

</thead>


<tbody>

<% subjects.forEach(subject => { %>

<tr class="border-b hover:bg-gray-50">

<td class="py-3 px-4">
<%= subject.name %>
</td>

<td class="py-3 px-4">
<%= subject.branch %>
</td>

<td class="py-3 px-4">
Semester <%= subject.semester %>
</td>


<td class="py-3 px-4 text-center space-x-3">

<a href="/subjects/edit/<%= subject._id %>"
class="bg-yellow-500 text-white px-3 py-1 rounded hover:bg-yellow-600">
Edit
</a>


<form action="/subjects/delete/<%= subject._id %>" method="POST" class="inline">

<button
onclick="return confirm('Are you sure you want to delete this subject?')"
class="bg-red-600 text-white px-3 py-1 rounded hover:bg-red-700">

Delete

</button>

</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

<% } %>

</div>



<!-- USER MANAGEMENT -->

<div class="bg-white shadow-lg rounded-xl p-6">

<h2 class="text-xl font-semibold text-gray-700 mb-5">
User Management
</h2>

<p class="text-gray-600 mb-4">
View and manage all registered users in the system.
</p>

<a href="/admin/users"
class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition">

View Users

</a>

</div>



</div>

</body>
</html>