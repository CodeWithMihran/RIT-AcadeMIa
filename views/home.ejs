<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<title>RIT AcadeMIA</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>


<body class="bg-slate-100 min-h-screen">


<!-- HERO SECTION -->

<section class="bg-indigo-600 text-white py-16">

<div class="max-w-7xl mx-auto px-6 text-center">

<h1 class="text-5xl font-bold mb-6">
Welcome to RIT AcadeMIA
</h1>

<p class="text-lg text-indigo-100 max-w-2xl mx-auto">
Your one-stop platform for syllabus, notes, PYQs, YouTube lectures and personal academic progress tracking.
</p>

</div>

</section>



<!-- FLASH MESSAGES -->

<div class="max-w-6xl mx-auto mt-6 px-6">

<% if (error.length > 0) { %>
<div class="bg-red-100 border border-red-300 text-red-700 px-4 py-3 rounded mb-4">
<%= error %>
</div>
<% } %>

<% if (success.length > 0) { %>
<div class="bg-green-100 border border-green-300 text-green-700 px-4 py-3 rounded mb-4">
<%= success %>
</div>
<% } %>

</div>



<!-- LOGIN + REGISTER -->

<section class="py-16">

<div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12">


<!-- REGISTER FORM -->

<div class="bg-white p-8 rounded-xl shadow-lg">

<h2 class="text-2xl font-bold text-slate-800 mb-6">
Create Account
</h2>

<form action="/auth/register" method="POST" class="space-y-4">

<input
type="text"
name="name"
placeholder="Full Name"
required
class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-400"
/>

<input
type="text"
name="branch"
placeholder="Branch (CSE, ECE, etc)"
required
class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-400"
/>

<input
type="number"
name="year"
placeholder="Year"
required
class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-400"
/>

<input
type="number"
name="semester"
placeholder="Semester"
required
class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-400"
/>

<input
type="email"
name="email"
placeholder="Email"
required
class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-400"
/>

<input
type="password"
name="password"
placeholder="Password"
required
class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-400"
/>

<input
type="password"
name="confirmPassword"
placeholder="Confirm Password"
required
class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-400"
/>

<button
type="submit"
class="w-full bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700 transition"
>

Register

</button>

</form>

</div>



<!-- LOGIN FORM -->

<div class="bg-white p-8 rounded-xl shadow-lg">

<h2 class="text-2xl font-bold text-slate-800 mb-6">
Login
</h2>

<form action="/auth/login" method="POST" class="space-y-4">

<input
type="email"
name="email"
placeholder="Email"
required
class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-400"
/>

<input
type="password"
name="password"
placeholder="Password"
required
class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-400"
/>

<button
type="submit"
class="w-full bg-green-600 text-white py-2 rounded-lg hover:bg-green-700 transition"
>

Login

</button>

</form>

</div>

</div>

</section>



<!-- FEATURES SECTION -->

<section class="bg-white py-16">

<div class="max-w-7xl mx-auto px-6">

<h2 class="text-3xl font-bold text-center text-slate-800 mb-12">
What RIT AcadeMIA Offers
</h2>


<div class="grid md:grid-cols-3 gap-8">


<div class="bg-slate-50 p-6 rounded-xl shadow">

<h3 class="text-xl font-semibold mb-3">
📚 Subject Resources
</h3>

<p class="text-gray-600">
Access syllabus, notes, PYQs and books organized by branch and semester.
</p>

</div>



<div class="bg-slate-50 p-6 rounded-xl shadow">

<h3 class="text-xl font-semibold mb-3">
🎥 Video Lectures
</h3>

<p class="text-gray-600">
Watch curated YouTube lectures for each unit and topic.
</p>

</div>



<div class="bg-slate-50 p-6 rounded-xl shadow">

<h3 class="text-xl font-semibold mb-3">
📊 Progress Tracker
</h3>

<p class="text-gray-600">
Track topic completion and visualize academic progress with smart analytics.
</p>

</div>


<div class="bg-slate-50 p-6 rounded-xl shadow">

<h3 class="text-xl font-semibold mb-3">
📖 Unit-wise Study
</h3>

<p class="text-gray-600">
All learning materials are structured unit-wise for easy preparation.
</p>

</div>



<div class="bg-slate-50 p-6 rounded-xl shadow">

<h3 class="text-xl font-semibold mb-3">
🎯 Topic Completion
</h3>

<p class="text-gray-600">
Mark topics as completed and track your study progress.
</p>

</div>



<div class="bg-slate-50 p-6 rounded-xl shadow">

<h3 class="text-xl font-semibold mb-3">
⚡ Smart Dashboard
</h3>

<p class="text-gray-600">
Get a clean dashboard showing your subjects and completion percentages.
</p>

</div>


</div>

</div>

</section>



<!-- FOOTER -->

<footer class="bg-slate-900 text-gray-300 text-center py-6">

<p>
© <%= new Date().getFullYear() %> RIT AcadeMIA — Academic Progress Platform
</p>

</footer>


</body>
</html>