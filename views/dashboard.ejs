<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<title>Dashboard | RIT AcadeMIA</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>


<body class="bg-slate-100 min-h-screen">


<!-- USER NAVBAR -->

<%- include("partials/navbar-user") %>


<!-- PAGE CONTAINER -->

<div class="max-w-7xl mx-auto px-6 py-10">


<!-- USER INFO -->

<div class="bg-white shadow-md rounded-xl p-6 mb-10">

<h1 class="text-3xl font-bold text-slate-800 mb-2">
Welcome, <%= user.name %> 👋
</h1>

<p class="text-gray-600">
Branch: <span class="font-medium"><%= user.branch %></span> |
Year: <span class="font-medium"><%= user.year %></span> |
Semester: <span class="font-medium"><%= user.semester %></span>
</p>

</div>



<!-- FLASH MESSAGES -->

<% if (error.length > 0) { %>

<div class="bg-red-100 border border-red-300 text-red-700 px-4 py-3 rounded mb-6">
<%= error %>
</div>

<% } %>


<% if (success.length > 0) { %>

<div class="bg-green-100 border border-green-300 text-green-700 px-4 py-3 rounded mb-6">
<%= success %>
</div>

<% } %>



<!-- SUBJECT SECTION -->

<h2 class="text-2xl font-bold text-slate-800 mb-6">
Your Subjects
</h2>


<% if (subjects.length === 0) { %>

<div class="bg-white p-6 rounded-lg shadow">

<p class="text-gray-600">
No subjects available for your branch and semester yet.
</p>

</div>

<% } else { %>


<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

<% subjects.forEach(subject => { %>


<!-- SUBJECT CARD -->

<div class="bg-white rounded-xl shadow-md p-6 hover:shadow-xl transition">


<h3 class="text-xl font-bold text-slate-800 mb-3">
<%= subject.name %>
</h3>


<p class="text-gray-600 mb-4">
Units Available: <span class="font-medium"><%= subject.units.length %></span>
</p>


<!-- ACTION BUTTONS -->

<div class="flex flex-col gap-3">


<a
href="/subjects/<%= subject._id %>"
class="bg-indigo-600 text-white py-2 rounded-lg text-center hover:bg-indigo-700 transition"
>

View Subject

</a>


<a
href="/progress/<%= subject._id %>"
class="bg-green-600 text-white py-2 rounded-lg text-center hover:bg-green-700 transition"
>

Open Progress Tracker

</a>


</div>


</div>


<% }) %>

</div>


<% } %>



<!-- QUICK FEATURES -->

<div class="mt-14 grid md:grid-cols-3 gap-6">


<div class="bg-white p-6 rounded-xl shadow">

<h3 class="text-lg font-semibold mb-2">
📚 Study Materials
</h3>

<p class="text-gray-600">
Access notes, books and PYQs unit-wise for every subject.
</p>

</div>


<div class="bg-white p-6 rounded-xl shadow">

<h3 class="text-lg font-semibold mb-2">
🎥 Video Lectures
</h3>

<p class="text-gray-600">
Watch recommended YouTube lectures for better understanding.
</p>

</div>


<div class="bg-white p-6 rounded-xl shadow">

<h3 class="text-lg font-semibold mb-2">
📊 Progress Tracking
</h3>

<p class="text-gray-600">
Track your topic completion and subject progress.
</p>

</div>


</div>


</div>


</body>
</html>