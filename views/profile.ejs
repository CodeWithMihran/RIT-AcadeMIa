<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<title>Profile | RIT Academia</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.tailwindcss.com"></script>

</head>


<body class="bg-gray-100 min-h-screen">

<!-- USER NAVBAR -->
<%- include("partials/navbar-user") %>


<div class="max-w-5xl mx-auto p-8">

<!-- PAGE TITLE -->

<div class="mb-8">

<h1 class="text-3xl font-bold text-gray-800">
Your Profile
</h1>

<p class="text-gray-500">
Manage your personal information
</p>

</div>


<!-- FLASH MESSAGES -->

<% if (error.length > 0) { %>

<div class="bg-red-100 border border-red-300 text-red-700 px-4 py-3 rounded mb-6">
<%= error %>
</div>

<% } %>


<% if (success.length > 0) { %>

<div class="bg-green-100 border border-green-300 text-green-700 px-4 py-3 rounded mb-6">
<%= success %>
</div>

<% } %>



<div class="grid md:grid-cols-3 gap-8">


<!-- PROFILE SUMMARY CARD -->

<div class="bg-white shadow-lg rounded-xl p-6 text-center">

<div class="w-24 h-24 mx-auto rounded-full bg-indigo-100 flex items-center justify-center text-3xl font-bold text-indigo-600">

<%= user.name.charAt(0).toUpperCase() %>

</div>

<h2 class="mt-4 text-xl font-semibold text-gray-800">
<%= user.name %>
</h2>

<p class="text-gray-500 text-sm">
<%= user.email %>
</p>

<div class="mt-6 space-y-2 text-gray-600 text-sm">

<p>
<span class="font-semibold">Branch:</span>
<%= user.branch %>
</p>

<p>
<span class="font-semibold">Year:</span>
<%= user.year %>
</p>

<p>
<span class="font-semibold">Semester:</span>
<%= user.semester %>
</p>

</div>

</div>



<!-- UPDATE PROFILE FORM -->

<div class="md:col-span-2 bg-white shadow-lg rounded-xl p-8">

<h2 class="text-xl font-semibold text-gray-800 mb-6">
Update Profile
</h2>

<form action="/users/profile/update" method="POST" class="space-y-5">


<div class="grid md:grid-cols-2 gap-4">

<div>
<label class="block text-sm font-medium text-gray-600">
Name
</label>

<input
type="text"
name="name"
value="<%= user.name %>"
required
class="w-full mt-1 p-3 border rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
/>
</div>


<div>
<label class="block text-sm font-medium text-gray-600">
Email
</label>

<input
type="email"
name="email"
value="<%= user.email %>"
required
class="w-full mt-1 p-3 border rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
/>
</div>

</div>



<div class="grid md:grid-cols-3 gap-4">

<div>
<label class="block text-sm font-medium text-gray-600">
Branch
</label>

<input
type="text"
name="branch"
value="<%= user.branch %>"
required
class="w-full mt-1 p-3 border rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
/>
</div>


<div>
<label class="block text-sm font-medium text-gray-600">
Year
</label>

<input
type="number"
name="year"
value="<%= user.year %>"
required
class="w-full mt-1 p-3 border rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
/>
</div>


<div>
<label class="block text-sm font-medium text-gray-600">
Semester
</label>

<input
type="number"
name="semester"
value="<%= user.semester %>"
required
class="w-full mt-1 p-3 border rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
/>
</div>

</div>



<button
type="submit"
class="w-full bg-indigo-600 text-white py-3 rounded-lg hover:bg-indigo-700 transition font-medium"
>

Update Profile

</button>


</form>

</div>

</div>

</div>


</body>
</html>