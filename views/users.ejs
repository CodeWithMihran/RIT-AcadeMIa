<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Manage Users - Admin - RIT Academia</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <h1>Manage Users</h1>
        <a href="/admin">Back to Dashboard</a> |
        <a href="/auth/logout">Logout</a>
    </header>

    <!-- Flash Messages -->
    <% if (error.length > 0) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <% if (success.length > 0) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <main>
        <% if (users.length === 0) { %>
            <p>No users found.</p>
        <% } else { %>
            <table border="1">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Branch</th>
                        <th>Year</th>
                        <th>Semester</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.name %></td>
                            <td><%= user.email %></td>
                            <td><%= user.branch %></td>
                            <td><%= user.year %></td>
                            <td><%= user.semester %></td>
                            <td><%= user.role %></td>
                            <td>
                                <a href="/admin/delete-user/<%= user._id %>">Delete</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </main>
</body>
</html>